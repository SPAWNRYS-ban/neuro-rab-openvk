# OpenVK Configuration
OPENVK_API_URL=http://localhost:8080
OPENVK_API_TOKEN=your_api_token_here
OPENVK_BOT_ID=1

# Claude AI Configuration (via tokenator.cloud)
CLAUDE_API_URL=https://api.tokenator.cloud/v1
CLAUDE_API_KEY=your_tokenator_api_key_here
CLAUDE_MODEL=claude-3-5-haiku-20241022

# DuckDuckGo Configuration
DUCKDUCKGO_API_URL=https://api.duckduckgo.com

# Database Configuration
DATABASE_PATH=./bot_cache.db

# Polling Configuration
POLLING_INTERVAL_SECS=6

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/bot.log
LOG_CONSOLE=true

# Web Scraping Configuration
MAX_PAGE_SIZE_MB=10
REQUEST_TIMEOUT_SECS=30

# Bot Behavior
BOT_MENTION_PREFIX=@НейроРаб
BOT_NAME=НейроРаб
CONTEXT_MEMORY_SIZE=10
