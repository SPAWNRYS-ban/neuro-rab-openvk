# OpenVK Configuration
OPENVK_API_URL=http://localhost:8080
OPENVK_API_TOKEN=your_api_token_here
OPENVK_BOT_ID=1
OPENVK_HIDE_ONLINE_ACTIVITY=0

# Bot Mode Configuration
BOT_MODE=global
LONGPOLL_RECONNECT_INTERVAL_SECS=5
LONGPOLL_MAX_RECONNECT_ATTEMPTS=10
LONGPOLL_BACKOFF_MULTIPLIER=1.5
LONGPOLL_MAX_WAIT_SECS=300

# Claude AI Configuration (via tokenator.cloud)
CLAUDE_API_URL=https://api.tokenator.cloud/v1
CLAUDE_API_KEY=your_tokenator_api_key_here
CLAUDE_MODEL=claude-3-5-haiku-20241022

# DuckDuckGo Configuration
DUCKDUCKGO_API_URL=https://api.duckduckgo.com

# Database Configuration
DATABASE_PATH=./bot_cache.db

# Polling Configuration
POLLING_INTERVAL_SECS=6
# How often (seconds) to poll notifications.get for @mentions and comments
NOTIF_POLL_INTERVAL_SECS=10


# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/bot.log
LOG_CONSOLE=true

# Web Scraping Configuration
MAX_PAGE_SIZE_MB=10
REQUEST_TIMEOUT_SECS=30

# Bot Behavior
BOT_MENTION_PREFIX=@НейроРаб
# Extra textual handles that count as mentioning the bot (comma-separated),
# e.g. the latin shortname used in real @-tags
BOT_MENTION_ALIASES=neuroslave,НейроРаб
BOT_NAME=НейроРаб
CONTEXT_MEMORY_SIZE=10
